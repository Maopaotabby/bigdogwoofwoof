  "derivedDimensions": {
    "resource": {
      "formula": "0.6*cursedEnergyScore + 0.4*efficiencyScore",
      "status": "provisional"
    },
    "control": {
      "formula": "0.7*controlScore + 0.3*efficiencyScore",
      "status": "provisional"
    },
    "body": {
      "formula": "0.55*martialScore + 0.45*bodyScore",
      "status": "provisional"
    },
    "growth": {
      "formula": "talentScore",
      "status": "provisional"
    },
    "basePowerScore": {
      "formula": "0.25*resource + 0.25*control + 0.25*body + 0.25*growth",
      "status": "provisional",
      "note": "Equal dimension weights are a temporary baseline until playtesting."
    }
  },
  "gradeWeightAdjustment": {
    "status": "legacyReference",
    "appliesToWheel": "legacy 59/126/142 grade wheels",
    "meaning": "历史版本使用等级评定抽取权重；当前版本改为 deterministicGradeRanges 直接判定等级。",
    "implementedInPrototype": true,
    "effectiveScoreFormula": "0.38*basePowerScore + 0.28*top1Raw + 0.20*top2Raw + 0.14*top3Raw + conservative highAttributeCountBonus, shifted into grade target bands where A-average anchors to grade1",
    "floorRules": {
      "martialSAndBodySS": "grade1 floor",
      "martialSSSAndBodySSS": "semiSpecialGrade1 floor",
      "anyBaseAttributeSSPlus": "semiSpecialGrade1 floor"
    },
    "targetScores": {
      "support": 0.8,
      "grade4": 2.4,
      "grade3": 4.5,
      "grade2": 6.3,
      "grade1": 7.3,
      "semiSpecialGrade1": 9.4,
      "specialGrade": 10.4
    },
    "notes": [
      "This is a second playable weighting curve for review, not a final balance decision.",
      "The curve now treats JJK grades as coarse bands: A remains a grade1 anchor; S/SS/SSS packages are needed before semiSpecial/special becomes natural.",
      "A strong body package can carry grade even when cursed-energy-side stats are poor.",
      "Low control/resource still matters for domain and technique outcomes, but no longer erases physical monsters in grade assessment.",
      "Debug mode displays base weight and adjusted weight for each grade option.",
      "1.12 update: grade output now has a bell-like prior centered on grade2/grade1; base attribute wheels remain equal-weight draws.",
      "1.12 update: any base attribute at SS/SSS/EX is above-grade1 floor, so grade1-or-lower options are removed for that character.",
      "Current update: grade output is no longer rolled from weighted grade wheels; effectiveScore maps directly to deterministic score bands and then applies floor rules."
    ],
    "distributionPrior": {
      "support": 0.6,
      "grade4": 0.8,
      "grade3": 1,
      "grade2": 1.55,
      "grade1": 1.55,
      "semiSpecialGrade1": 0.12,
      "specialGrade": 0.04
    },
    "strongPowerGate": {
      "effectiveScoreAtLeast": 9.6,
      "orCondition": "ssPlusCountAtLeast 5 and gradeFloor semiSpecialGrade1"
    }
  },
