  "sourceLayer": ["site_1.386B_action_layer", "site_1.386C_domain_profile_layer", "prototype_balance"],
  "scope": "candidate three-choice action templates for nonstandard trial targets in rule domains",
  "notes": [
    "This file is a data-layer extension for rule/trial domain target behavior only.",
    "These actions are not cards, do not form a deck, and must not be treated as final canon rulings.",
    "AI may narrate selected actions after local resolution, but AI must not invent trial rules, verdict outcomes, confiscation targets, or final penalties.",
    "Each target class exposes exactly three candidate choices for the lightweight trial sub-phase."
  ],
  "choiceCount": 3,
  "standardTargetClasses": [
    "high_intelligence_curse",
    "low_grade_curse",
    "shikigami",
    "cursed_tool"
  ],
